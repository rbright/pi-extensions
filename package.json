{
  "name": "pi-extensions",
  "private": true,
  "workspaces": [
    "extensions/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@rbright/notify-desktop",
    "format": "oxfmt -c .oxfmtrc.json --ignore-path .oxfmtignore --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "oxfmt -c .oxfmtrc.json --ignore-path .oxfmtignore --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml}\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "bun run format:check && turbo run lint typecheck test build",
    "check:desktop": "bun run format:check && turbo run lint typecheck test build --filter=@rbright/notify-desktop",
    "clean": "turbo run clean && rm -rf .turbo node_modules",
    "publish:desktop": "bun run check:desktop && npm publish --workspace extensions/notify-desktop --access public --provenance"
  },
  "devDependencies": {
    "@types/node": "25.0.9",
    "@vitest/coverage-v8": "4.0.17",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tsup": "8.5.0",
    "turbo": "2.5.8",
    "typescript": "5.9.3",
    "vitest": "4.0.17"
  },
  "packageManager": "bun@1.3.9"
}
