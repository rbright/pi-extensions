{
  "name": "@rbright/notify-desktop",
  "version": "0.2.0",
  "description": "OSC desktop notifications for Pi agent turn completion.",
  "keywords": [
    "desktop",
    "notifications",
    "osc",
    "pi",
    "pi-coding-agent",
    "pi-package"
  ],
  "homepage": "https://github.com/rbright/pi-extensions/tree/main/extensions/notify-desktop#readme",
  "bugs": {
    "url": "https://github.com/rbright/pi-extensions/issues"
  },
  "license": "MIT",
  "author": "Ryan Bright <ryan@moonriselabs.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rbright/pi-extensions.git",
    "directory": "extensions/notify-desktop"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "clean": "rm -rf coverage dist",
    "lint": "oxlint src/**/*.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check": "bun run lint && bun run typecheck && bun run test",
    "prepublishOnly": "bun run check && bun run build"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
